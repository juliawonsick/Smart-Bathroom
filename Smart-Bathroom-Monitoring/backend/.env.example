# ============================================================
#  SmartBathroom — Configuração de Ambiente
#  Copie este arquivo para .env e preencha os valores
# ============================================================

# --- Flask ---
PORT=5000
SECRET_KEY=smartbathroom_secret_key_2026

# --- ngrok (opcional) ---
# Obtenha seu token em https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# --- arduino_raspberry.py (rodar no Raspberry Pi) ---
# URL do servidor Flask.
#   - Se Flask e Raspberry Pi estão na mesma rede: use o IP local da máquina Windows
#     Exemplo: SERVER_URL=http://192.168.1.100:5000
#   - Se estiver usando ngrok: use a URL pública
#     Exemplo: SERVER_URL=https://xxxx-xxx.ngrok-free.app
SERVER_URL=http://localhost:5000

# Porta serial do Arduino conectado ao Raspberry Pi
#   Linux (Raspberry Pi): /dev/ttyUSB0  ou  /dev/ttyACM0
#   Windows (teste local): COM3  ou  COM4
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600
RETRY_DELAY=5
