# ============================================================
#  SmartBathroom — Configuração de Ambiente (Raspberry Pi)
#  Copie este arquivo para .env e ajuste se necessário
# ============================================================

# --- Flask ---
PORT=5000
SECRET_KEY=smartbathroom_secret_key_2026

# --- Ponte Arduino (lê o serial e manda pro Flask, tudo na mesma Raspberry) ---
# Como tudo roda no mesmo processo/máquina, o servidor é sempre localhost:
SERVER_URL=http://localhost:5000

# Porta serial do Arduino conectado na Raspberry via USB.
# Descubra rodando: ls /dev/tty*  (geralmente /dev/ttyUSB0 ou /dev/ttyACM0)
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=9600
RETRY_DELAY=5

# --- ngrok (OPCIONAL) ---
# Deixe vazio para rodar só local (ex: na Raspberry, na rede do campus).
# Preencha com seu token (https://dashboard.ngrok.com/get-started/your-authtoken)
# para gerar uma URL pública — útil pra testar fora da faculdade,
# sem a Raspberry/Arduino por perto.
NGROK_AUTHTOKEN=

# Defina como 1 só se quiser testar a interface web SEM o Arduino conectado
DISABLE_ARDUINO_BRIDGE=0
